# ---- App ----
APP_NAME=Jarvis
ENVIRONMENT=development        # development | staging | production
DEBUG=true
SECRET_KEY=change-me-to-a-random-64-char-string
API_V1_PREFIX=/api/v1
CORS_ORIGINS=http://localhost:5173

# ---- Auth ----
ACCESS_TOKEN_EXPIRE_MINUTES=60
REFRESH_TOKEN_EXPIRE_DAYS=7
JWT_ALGORITHM=HS256

# ---- Database ----
# SQLite for local dev (default). Swap for Postgres in production:
# DATABASE_URL=postgresql+psycopg://jarvis:jarvis@localhost:5432/jarvis
DATABASE_URL=sqlite:///./data/jarvis.db

# ---- Redis (task queue / cache, optional in dev) ----
REDIS_URL=redis://localhost:6379/0

# ---- AI Providers ----
# Set the one(s) you have keys for. DEFAULT_AI_PROVIDER picks which is used
# when a plugin doesn't request a specific provider.
DEFAULT_AI_PROVIDER=anthropic   # anthropic | openai | gemini

ANTHROPIC_API_KEY=
ANTHROPIC_DEFAULT_MODEL=claude-sonnet-5

OPENAI_API_KEY=
OPENAI_DEFAULT_MODEL=gpt-4.1

GEMINI_API_KEY=
GEMINI_DEFAULT_MODEL=gemini-2.5-pro

# ---- Logging ----
LOG_LEVEL=INFO
LOG_FORMAT=json                # json | console
LOG_FILE=./data/logs/jarvis.log

# ---- Security ----
# Generate with:
#   python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
CREDENTIAL_ENCRYPTION_KEY=
FRONTEND_BASE_URL=http://localhost:5173

# ---- Integrations (leave blank until you connect each service) ----
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
# Legacy — no longer read directly by the OAuth flow, see
# GOOGLE_OAUTH_REDIRECT_BASE_URL below. Harmless to leave set or blank.
GOOGLE_REDIRECT_URI=
# Base every Google-backed capability's callback is built from:
# {base}/{capability}/callback (e.g. .../integrations/email/callback,
# .../integrations/google_calendar/callback). Each resulting URL must be
# added as its own "Authorized redirect URI" on the same OAuth client in
# Google Cloud Console.
GOOGLE_OAUTH_REDIRECT_BASE_URL=http://localhost:8000/api/v1/integrations

# Investment Dashboard live prices/news — free key at https://finnhub.io.
# Blank = the dashboard shows an honest "not configured" state instead of
# sample data.
FINNHUB_API_KEY=

QUICKBOOKS_CLIENT_ID=
QUICKBOOKS_CLIENT_SECRET=
QUICKBOOKS_ENVIRONMENT=sandbox

AMAZON_SP_API_CLIENT_ID=
AMAZON_SP_API_CLIENT_SECRET=
AMAZON_SP_API_REFRESH_TOKEN=

SHOPIFY_SHOP_URL=
SHOPIFY_ACCESS_TOKEN=

# Shopify read-only integration (Phase 1).
#
# Current method — Dev Dashboard app (client credentials grant):
#   Create the app in Shopify's Dev Dashboard, assign ONLY read scopes, and
#   install it on your store. New Dev Dashboard apps do NOT expose a static
#   `shpat_` token; instead copy the Client ID + Secret from
#   Dev Dashboard > (your app) > Settings, and set the two vars below. Jarvis
#   exchanges them for a 24h access token automatically.
#
# Legacy method — older admin-created "Develop apps":
#   If you still have a `shpat_...`, set SHOPIFY_ADMIN_API_TOKEN instead (it
#   takes priority and skips the token exchange).
#
# SHOPIFY_WORKSPACE_ID binds the store to exactly one Jarvis workspace (Primal
# Penni's company id) — Shopify data is served only when that workspace is
# active. Leave the auth vars blank to keep the integration "not configured".
# These belong in .env ONLY (git-ignored) — never commit real values.
# Required READ scopes on the Shopify app (configured on the app itself via
# the Shopify CLI / its shopify.app.toml [access_scopes], NOT in this repo —
# Jarvis is only the API client). The client-credentials token grants exactly
# the app's active-version scopes; if this list is missing there, every
# resource except basic `shop` returns "Access denied":
#   read_products, read_inventory, read_locations, read_orders, read_customers,
#   read_discounts, read_themes, read_content, read_metaobjects,
#   read_metaobject_definitions
SHOPIFY_STORE_DOMAIN=            # e.g. primal-penni.myshopify.com
SHOPIFY_CLIENT_ID=              # Dev Dashboard > app > Settings > Client ID
SHOPIFY_CLIENT_SECRET=          # Dev Dashboard > app > Settings > Secret
SHOPIFY_ADMIN_API_TOKEN=        # legacy shpat_... (optional; only if you have one)
SHOPIFY_API_VERSION=2025-01
SHOPIFY_WORKSPACE_ID=           # Primal Penni's company UUID (from /api/v1/companies)

TWITTER_API_KEY=
TWITTER_API_SECRET=
INSTAGRAM_ACCESS_TOKEN=
LINKEDIN_ACCESS_TOKEN=
FACEBOOK_ACCESS_TOKEN=
